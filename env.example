# SQL Server Configuration
DB_SERVER=localhost
DB_USER=sa
DB_PASSWORD=YourPassword123
DB_NAME=Data_PersonalizedSystem

# Server Configuration
PORT=3001

# Email Configuration (Brevo Transactional API - preferred, API key usually starts with xkeysib-)
BREVO_API_KEY=<YOUR_BREVO_API_KEY>

# Email Configuration (Brevo SMTP - fallback if BREVO_API_KEY is empty, SMTP key usually starts with xsmtpsib-)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=<YOUR_BREVO_SMTP_LOGIN>
SMTP_PASS=<YOUR_BREVO_SMTP_KEY>

EMAIL_FROM=no-reply@learn-dashboard.shopsheap.online

# Frontend URL
FRONTEND_URL=http://localhost:5173

# Activity tracking and reminder
ACTIVITY_HEARTBEAT_INTERVAL_SECONDS=10
INACTIVITY_REMINDER_DAYS=5
INACTIVITY_SCAN_INTERVAL_HOURS=24

# JWT Secret Keys
JWT_SECRET=7846451fde1e6e43af1e5a2b022188f2
JWT_REFRESH_SECRET=f36442001ff6b4958b8876d2e1acde75640714c6
